# Application
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Database
MONGO_URI=mongodb://localhost:27017/wdp301_historytalk

# Security & CORS
CORS_ORIGIN=http://localhost:3000

# JWT — use separate secrets for access and refresh tokens
JWT_SECRET=your_access_token_secret_long_and_random
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_token_secret_long_and_random
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth — get from https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# PayOS — get credentials from https://my.payos.vn (Payment channel → API)
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
# PayOS REST base URL (rarely changed)
PAYOS_BASE_URL=https://api-merchant.payos.vn
# Frontend pages PayOS redirects the buyer to after checkout (success & cancel)
PAYOS_RETURN_URL=http://localhost:3000/payment/result
PAYOS_CANCEL_URL=http://localhost:3000/payment/result
